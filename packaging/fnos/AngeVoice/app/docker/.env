# AngeVoice fnOS default run mode. This file contains no passwords or API keys.
# The fnOS setup wizard rewrites these values when the user selects a run mode.
ANGEVOICE_FNOS_RUN_MODE=cpu
ANGEVOICE_FNOS_IMAGE=ghcr.io/ang77712829/angevoice-cpu:latest
ANGEVOICE_FNOS_RUNTIME=runc
ANGEVOICE_FNOS_PROFILE=cpu
ANGEVOICE_FNOS_KOKORO_DEVICE=cpu
ANGEVOICE_FNOS_MOSS_PROVIDER=cpu
ANGEVOICE_FNOS_MOSS_CUDA_ENABLED=false
ANGEVOICE_FNOS_ZIPVOICE_PROVIDER=cpu
ANGEVOICE_FNOS_ZIPVOICE_CUDA_ENABLED=false
ANGEVOICE_FNOS_NVIDIA_VISIBLE_DEVICES=void
